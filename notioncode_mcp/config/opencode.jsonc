{
  "$schema": "https://opencode.ai/config.json",
  "model": "notion-fable/fable-5",
  "provider": {
    "notion-fable": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Notion AI",
      "options": {
        "baseURL": "http://127.0.0.1:8765/v1",
        "apiKey": "local"
      },
      "models": {
        "fable-5": {
          "name": "Fable 5 (Notion)",
          "limit": {
            "context": 100000,
            "output": 40000
          }
        },
        "gpt-5.6-sol": {
          "name": "GPT-5.6 Sol (Notion)",
          "limit": {
            "context": 100000,
            "output": 40000
          }
        }
      }
    }
  },
  "mcp": {
    "notion-private": {
      "type": "local",
      "command": [
        "node",
        "__NOTIONCODE_ROOT__/notion-private-api-mcp/run-from-account.js"
      ],
      "enabled": true,
      "timeout": 10000
    }
  }
}
