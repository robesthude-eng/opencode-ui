{
  "name": "opencode-ui",
  "private": true,
  "version": "0.3.1",
  "type": "module",
  "description": "A custom web UI for OpenCode (sst/opencode), built on its headless HTTP + SSE API.",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:frontend": "vitest run src/__tests__",
    "test:server": "vitest run server/__tests__",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc -b",
    "ci": "npm run lint && npm run test:all && npm run build"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@sentry/node": "^10.65.0",
    "@sentry/react": "^10.65.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/react-router": "^1.170.17",
    "adm-zip": "^0.5.18",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "idb-keyval": "^6.3.0",
    "lucide-react": "^0.525.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "16.3.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.10",
    "babel-plugin-react-compiler": "^19.1.0-rc.2",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.1.14",
    "typescript": "5.9.3",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.0.3",
    "vitest": "4.1.10"
  }
}
