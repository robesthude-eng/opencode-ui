{
  "name": "opencode-ui",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "A custom web UI for OpenCode (sst/opencode), built on its headless HTTP + SSE API.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:frontend": "vitest run src/__tests__",
    "test:server": "vitest run server/__tests__",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-virtual": "^3.14.5",
    "adm-zip": "^0.5.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.2",
    "vite": "^7.0.0",
    "vitest": "^4.1.10"
  }
}
