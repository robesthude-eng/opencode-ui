{
  "name": "opencode-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A custom web UI for OpenCode (sst/opencode), built on its headless HTTP + SSE API.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:frontend": "vitest run src/__tests__",
    "test:server": "node --experimental-vm-modules node_modules/.bin/jest server/__tests__ --config jest.config.cjs",
    "test:all": "npm run test:frontend && npm run test:server",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.5",
    "adm-zip": "^0.5.18",
    "http-proxy": "^1.18.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "sql.js": "^1.14.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^4.1.10"
  }
}
