{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "buildArgs": {
      "DEPLOY_TS": "auto"
    }
  },
  "deploy": {
    "startCommand": "sh start.sh",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 60
  }
}
