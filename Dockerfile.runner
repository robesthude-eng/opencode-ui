# ===== opencode-runner: изолированный контейнер одной сессии =====
# Внутри работает только opencode serve + инструменты агента (node, git, python).
# Сюда монтируется ТОЛЬКО каталог одной сессии (/session). Ни кода платформы,
# ни docker.sock, ни чужих сессий здесь нет.
# Сборка: docker compose --profile build-runner build runner-image
FROM node:24-slim

ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

RUN apt-get update && apt-get install -y --no-install-recommends \
    git ca-certificates curl bash python3 make g++ procps sudo \
  && npx playwright install-deps chromium \
  && npx playwright install chromium \
  && chmod -R 777 /ms-playwright \
  && update-ca-certificates \
  && echo "node ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/node \
  && chmod 0440 /etc/sudoers.d/node \
  && rm -rf /var/lib/apt/lists/*

RUN npm install -g opencode-ai@1.18.3

COPY runner-entry.sh /usr/local/bin/runner-entry.sh
RUN chmod +x /usr/local/bin/runner-entry.sh

ENV HOME=/session/.home
# Единая таймзона для таймстемпов независимо от хоста/датацентра.
ENV TZ=UTC
EXPOSE 4096

# Процессы раннера не работают из-под root; прокси дополнительно передаёт
# --user при docker run (см. server/runner.mjs, RUNNER_USER).
USER node

CMD ["sh", "/usr/local/bin/runner-entry.sh"]
