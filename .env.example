# Where the OpenCode headless server is running.
# Used by vite.config.ts to set up the /api proxy (avoids CORS).
# OPENCODE_TARGET=http://localhost:4096

# Production server
# PORT=3000
# NODE_ENV=production
# OPENCODE_WORKDIR=/app/workspace
# OC_SYSTEM_PORT=4096

# Session cookie TTL (ms). Default: 7 days.
# OPENCODE_SESSION_TTL_MS=604800000

# Force Secure cookies even outside production detection.
# COOKIE_SECURE=1

# Single-operator Basic Auth password mode (used when no users registered yet)
# OPENCODE_SERVER_PASSWORD=
# OPENCODE_UI_PASSWORD=
# OPENCODE_SERVER_USER=opencode

# Comma-separated emails that always have admin role
# OPENCODE_ADMIN_EMAILS=you@example.com

# Logging
# LOG_LEVEL=info

# SQLite lives at $OPENCODE_WORKDIR/opencode.db (auto-migrates legacy JSON)

# Password pepper (HMAC before scrypt). Set once and keep secret.
# OPENCODE_PASSWORD_PEPPER=long-random-string

# Optional Sentry
# Browser (public DSN, baked into Vite build):
# VITE_SENTRY_DSN=https://...@....ingest.sentry.io/...
# Server (private DSN):
# SENTRY_DSN=https://...@....ingest.sentry.io/...

# DB backups: daily under $OPENCODE_WORKDIR/backups/
# Optional webhook after each backup (for off-site pull/notify):
# BACKUP_WEBHOOK_URL=https://hooks.example.com/opencode-backup
# BACKUP_WEBHOOK_TOKEN=secret
