# Where the OpenCode headless server is running.
# Used by vite.config.ts to set up the /api proxy (avoids CORS).
# OPENCODE_TARGET=http://localhost:4096

# Production server
# PORT=3000
# NODE_ENV=production
# OPENCODE_WORKDIR=/app/workspace
# OC_SYSTEM_PORT=4096

# Session cookie TTL (ms). Default: 7 days.
# OPENCODE_SESSION_TTL_MS=604800000

# Force Secure cookies even outside production detection.
# COOKIE_SECURE=1

# Comma-separated socket peer IPs allowed to supply X-Forwarded-For,
# X-Forwarded-Host and X-Forwarded-Proto. Leave unset when exposing port 3000
# directly. Never add public/client IP ranges here.
# TRUSTED_PROXY_IPS=127.0.0.1,::1

# Shared rate-limit store for multi-instance deployments. All UI instances must
# use the same Redis endpoint. Supports redis:// and rediss:// URLs.
# RATE_LIMIT_REDIS_URL=rediss://:password@redis.example.com:6380/0
# RATE_LIMIT_REDIS_PREFIX=opencode-ui:rate-limit:
# RATE_LIMIT_REDIS_TIMEOUT_MS=1000

# Comma-separated emails that always have admin role
# OPENCODE_ADMIN_EMAILS=you@example.com

# GitHub PAT is read from the process environment only; never put it in origin URL.
# GITHUB_TOKEN=ghp_...
# GITHUB_PAT=ghp_...

# Self-improvement operation timeouts (milliseconds)
# SELF_IMPROVE_GIT_TIMEOUT_MS=30000
# SELF_IMPROVE_NPM_TIMEOUT_MS=300000
# SELF_IMPROVE_VITE_TIMEOUT_MS=600000
# SELF_IMPROVE_BIOME_TIMEOUT_MS=60000
# SELF_IMPROVE_TSC_TIMEOUT_MS=120000
# SELF_IMPROVE_TEST_TIMEOUT_MS=120000
# SELF_IMPROVE_AUTOCORRECT_TIMEOUT_MS=300000

# Logging
# LOG_LEVEL=info

# SQLite lives at $OPENCODE_WORKDIR/opencode.db (auto-migrates legacy JSON)

# Password pepper (HMAC before scrypt). Set once and keep secret.
# OPENCODE_PASSWORD_PEPPER=long-random-string

# Optional Sentry
# Browser (public DSN, baked into Vite build):
# VITE_SENTRY_DSN=https://...@....ingest.sentry.io/...
# Server (private DSN):
# SENTRY_DSN=https://...@....ingest.sentry.io/...

# DB backups: daily under $OPENCODE_WORKDIR/backups/
# Optional webhook after each backup (for off-site pull/notify):
# BACKUP_WEBHOOK_URL=https://hooks.example.com/opencode-backup
# BACKUP_WEBHOOK_TOKEN=secret

# --- Runner isolation: per-session container resources ---
# Каждый чат = отдельный контейнер с лимитами. Если задача агента строит
# большие структуры в памяти (например генерация карты), слишком низкий
# лимит приводит к OOM-kill ядром: умирает весь контейнер вместе с
# OpenCode (--restart no), и сессия навсегда отдаёт 502.
# Дефолт 1536m/1cpu подобран под 4-гиговый single-user бокс (одна тяжёлая
# сессия с запасом). На хостах с меньшим объёмом RAM или при высокой
# параллельности СНИЖАЙТЕ через .env (например RUNNER_MEMORY=512m) —
# иначе несколько раннеров одновременно уведут хост в swap/oom.
# RUNNER_MEMORY=1536m
# RUNNER_CPUS=1
