# Where the OpenCode headless server is running.
# Used by vite.config.ts to set up the /api proxy (avoids CORS).
# OPENCODE_TARGET=http://localhost:4096

# Production server
# PORT=3000
# NODE_ENV=production
# OPENCODE_WORKDIR=/app/workspace
# OC_SYSTEM_PORT=4096

# Session cookie TTL (ms). Default: 7 days.
# OPENCODE_SESSION_TTL_MS=604800000

# Force Secure cookies even outside Railway/production detection.
# COOKIE_SECURE=1

# Single-operator Basic Auth password mode (used when no users registered yet)
# OPENCODE_SERVER_PASSWORD=
# OPENCODE_UI_PASSWORD=
# OPENCODE_SERVER_USER=opencode

# Comma-separated emails that always have admin role
# OPENCODE_ADMIN_EMAILS=you@example.com

# Logging
# LOG_LEVEL=info

# SQLite lives at $OPENCODE_WORKDIR/opencode.db (auto-migrates legacy JSON)
